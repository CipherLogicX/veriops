# ================================================================
# TrackQA — Environment Configuration
# Copy to .env and fill in values. NEVER commit .env.
# Generate secrets: openssl rand -hex 32
# ================================================================

# ── Runtime ────────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false
UVICORN_WORKERS=2

# ── Database ───────────────────────────────────────────────────
POSTGRES_USER=trackqa
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_DB_PASSWORD
POSTGRES_DB=trackqa

# ── JWT (min 32 random hex chars) ─────────────────────────────
JWT_SECRET_KEY=CHANGE_THIS_REPLACE_WITH_openssl_rand_hex_32
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Redis ──────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_THIS_REDIS_PASSWORD@redis:6379/0

# ── First admin (bootstrapped once on first start) ─────────────
# Password must be ≥12 chars, upper+lower+digit
FIRST_ADMIN_EMAIL=admin@example.com
FIRST_ADMIN_PASSWORD=CHANGE_ME_Strong1!
FIRST_ADMIN_NAME=System Administrator

# ── Organisation ───────────────────────────────────────────────
DEFAULT_ORG_NAME=My Organisation

# ── HTTPS / CORS (use your actual domain) ─────────────────────
APP_BASE_URL=https://trackqa.example.local
CORS_ORIGINS=https://trackqa.example.local
COOKIE_SECURE=true
FORCE_HTTPS=true

# ── AI provider: local | disabled
AI_PROVIDER=local

# Local AI runtime — llama.cpp via trackqa-ai.service

LOCAL_AI_BASE_URL=http://ai:8080/v1
LOCAL_AI_MODEL=trackqa-qwen3-4b-q4
